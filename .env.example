# ============================================================
# PORTFOLIO ENVIRONMENT VARIABLES — Copy to .env.local
# ============================================================

# ---- App ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Anubhav Singh | Portfolio"

# ---- Database (PostgreSQL via Neon or Supabase) ----
# Get from: https://neon.tech → Create project → Connection string
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
# Required for Prisma migrations on Neon (direct connection, no pooling)
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# ---- Authentication (NextAuth v5) ----
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-super-secret-nextauth-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# ---- Admin Credentials (stored in DB after seed) ----
ADMIN_EMAIL="jonsnower07@gmail.com"
ADMIN_PASSWORD="change-me-after-first-login"

# ---- GitHub Integration ----
# Get from: https://github.com/settings/tokens
# Scopes needed: read:user, public_repo
GITHUB_USERNAME="UnknownHawkins"
GITHUB_TOKEN="ghp_your_github_token_here"

# ---- Contact / Discord Notification ----
# Get from: Discord Server → Integrations → Webhooks
CONTACT_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN"

# ---- Redis Cache (Upstash — Free Tier) ----
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL="https://your-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-upstash-token"

# ---- Rate Limiting ----
# Contact form: requests per window
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW=60  # seconds
